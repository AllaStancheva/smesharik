# Шаблон секретов. Скопируй этот файл в .env и впиши реальные значения руками.
# Сам .env в git НЕ попадает (см. .gitignore). Этот .env.example — попадает,
# как документация: какие переменные нужны боту.

# Токен Telegram-бота — получить у @BotFather
TELEGRAM_BOT_TOKEN=

# Ключ OpenRouter — из openrouter.ai/keys (тот же аккаунт, что у учебного бота)
OPENROUTER_API_KEY=

# Telegram-ID хозяина (число). Бот личный — отвечает только этому ID,
# остальных вежливо отшивает без траты баланса. Свой ID можно взять из .env
# учебного бота slimteambouw (там он уже есть) или узнать у бота @userinfobot.
ADMIN_ID=
